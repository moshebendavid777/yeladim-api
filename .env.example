PORT=4100
APP_URL=http://localhost:4100
PUBLIC_SITE_URL=http://localhost:5175
OWNER_ADMIN_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5175,https://eynomer.com,https://www.eynomer.com,https://controladm.eynomer.com,https://owner.eynomer.com

# Use a long random value in production.
JWT_SECRET=replace-with-64-random-characters
MESSAGE_ENCRYPTION_KEY=replace-with-32-byte-base64-key
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-first-owner-password
OWNER_NAME=Platform Owner

# Production database target.
DATABASE_URL=postgresql://yeladim:password@localhost:5432/yeladim

# Email provider placeholder.
SALES_EMAIL=sales@yeladim.app
EMAIL_PROVIDER=postmark
POSTMARK_SERVER_TOKEN=

# Media storage. STORAGE_PROVIDER can be "spaces" or "s3".
STORAGE_PROVIDER=spaces
STORAGE_BUCKET=yeladim-centers-staging
STORAGE_REGION=nyc3
STORAGE_ENDPOINT=https://nyc3.digitaloceanspaces.com
STORAGE_CDN_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# AWS-only optional encryption alias.
S3_KMS_KEY_ALIAS=alias/yeladim-media

# Push placeholders.
EXPO_ACCESS_TOKEN=
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
